{
  "name": "LearningOn",
  "version": "1.0.0",
  "description": "Online Learning Platform with Courses, Blogs & Tutors",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"tsc --watch\" \"nodemon dist/index.js\"",
    "build": "npm install && tsc",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:unit": "vitest run src/tests/unit",
    "test:integration": "vitest run src/tests/integration",
    "test:scenario": "vitest run src/tests/scenario",
    "test:e2e": "vitest run src/tests/e2e"
  },
  "keywords": [],
  "author": "Mahbubul Haque",
  "license": "ISC",
  "dependencies": {
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.6",
    "bcrypt": "^5.1.0",
    "body-parser": "^1.20.2",
    "cloudinary": "^2.2.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "google-auth-library": "^10.7.0",
    "jsonwebtoken": "^9.0.1",
    "mongoose": "^7.4.1",
    "mongoose-unique-validator": "^4.0.0",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^4.2.1",
    "redis": "^5.12.1",
    "socket.io": "^4.7.2",
    "stripe": "^13.3.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.19",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.19.39",
    "@vitest/coverage-v8": "^3.2.4",
    "mongodb-memory-server": "^10.4.3",
    "nodemon": "^3.0.1",
    "supertest": "^7.2.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
